# AI Service Environment Variables (Stateless)

# Server
PORT=3434
PRODUCTION=false

# Database (PostgreSQL for pgvector storage)
DATABASE_URL=postgresql://username:password@localhost:5432/examio_db

# ============ GEMINI MULTI-KEY/MODEL ROTATION ============
# Danh sách 2 API keys phân cách bởi dấu phẩy - tự động xoay vòng khi hết quota
GEMINI_API_KEYS=key1,key2

# Danh sách models phân cách bởi dấu phẩy - tự động xoay vòng khi model fail
GEMINI_MODEL_NAMES=gemini-2.0-flash,gemini-1.5-flash

# ============ AI2 Content Generation (OpenAI-compatible) ============
# Used only for quiz/flashcard/content generation. Do not use AI2 for OCR embeddings.
AI2_BASE_URL=https://ai2.devt.vn/v1
AI2_API_KEY=
AI2_GENERATION_MODEL_NAMES=minimax-m2.5-free,nemotron-3-super-free,trinity-large-preview-free
AI2_DEFAULT_MODEL=minimax-m2.5-free
AI2_TIMEOUT_SECONDS=3600
AI2_MAX_TOKENS=4096

# Tutor/chat stream: keep pre-AI retrieval and prompt history small for faster first token.
TUTOR_FAST_RETRIEVAL_TIMEOUT_SECONDS=0.5
CHAT_HISTORY_MAX_MESSAGES=4
CHAT_HISTORY_MAX_CHARS=1200

# ============ LLM Configuration - Ollama (OCR/Embedding Only) ============
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text:latest
RAG_MODEL=qwen3:8b

# Model Settings
DEFAULT_MODEL_ID=minimax-m2.5-free
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=4096
DEFAULT_MAX_TOKENS_CAP=4096

# RabbitMQ (for async OCR processing)
RABBITMQ_URL=amqp://localhost:5672
